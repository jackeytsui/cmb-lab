{
  "framework": "nextjs",
  "buildCommand": "node scripts/apply-migrations.mjs && npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/ghl-webhooks",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/ghl-inactive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/discord-sync",
      "schedule": "0 9 * * *"
    }
  ]
}
