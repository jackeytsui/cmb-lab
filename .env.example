# =============================================================================
# CantoMando Blueprint LMS - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Database
# -----------------------------------------------------------------------------

# Neon PostgreSQL connection string (pooled)
# Get from: Neon Console -> Project -> Connection Details -> Connection string (pooled)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# -----------------------------------------------------------------------------
# 2. Clerk Authentication
# -----------------------------------------------------------------------------

# Clerk publishable key (exposed to browser)
# Get from: Clerk Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Clerk secret key (server-side only)
# Get from: Clerk Dashboard -> API Keys
CLERK_SECRET_KEY=sk_test_xxx

# Clerk webhook signing secret for user sync
# Get from: Clerk Dashboard -> Webhooks -> Select endpoint -> Signing secret
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk auth page routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# 3. Mux Video
# -----------------------------------------------------------------------------

# Mux API access tokens for video upload and management
# Get from: Mux Dashboard -> Settings -> API Access Tokens
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Mux webhook signing secret for video processing events
# Get from: Mux Dashboard -> Settings -> Webhooks -> Signing Secret
MUX_WEBHOOK_SECRET=your-mux-webhook-secret

# Optional: Test video playback ID for /test-video page (uses Mux demo video if not set)
# Get from: Mux Dashboard -> Video -> Assets -> Select asset -> Playback ID
NEXT_PUBLIC_TEST_MUX_PLAYBACK_ID=your-playback-id

# Optional: Mux playback ID for /test-interactive page
# Get from: Mux Dashboard -> Video -> Assets -> Select asset -> Playback ID
NEXT_PUBLIC_MUX_PLAYBACK_ID=your-playback-id

# -----------------------------------------------------------------------------
# 4. OpenAI
# -----------------------------------------------------------------------------

# OpenAI API key for AI chatbot, grading assistance, and realtime voice
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# 5. Upstash Redis (Rate Limiting)
# -----------------------------------------------------------------------------

# Upstash Redis REST API credentials for API rate limiting
# Get from: Upstash Console -> Redis -> Select database -> REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# 6. n8n Webhooks
# -----------------------------------------------------------------------------

# n8n webhook URL for text interaction grading
# Get from: n8n -> Grading workflow -> Webhook node -> Production URL
N8N_GRADING_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/grade

# n8n webhook URL for audio interaction grading
# Get from: n8n -> Audio grading workflow -> Webhook node -> Production URL
N8N_AUDIO_GRADING_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/grade-audio

# n8n webhook URL for coach feedback notifications
# Get from: n8n -> Coach feedback workflow -> Webhook node -> Production URL
N8N_COACH_FEEDBACK_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/coach-feedback

# Shared auth header value sent with n8n webhook requests
# Generate: openssl rand -hex 32
N8N_WEBHOOK_AUTH_HEADER=your-shared-webhook-secret

# -----------------------------------------------------------------------------
# 7. GoHighLevel CRM
# -----------------------------------------------------------------------------

# Optional: GoHighLevel API token for CRM integration
# Get from: GHL Dashboard -> Settings -> API Keys
GHL_API_TOKEN=your-ghl-api-token

# Optional: GoHighLevel location (sub-account) ID
# Get from: GHL Dashboard -> Settings -> Business Info -> Location ID
GHL_LOCATION_ID=your-ghl-location-id

# Optional: GoHighLevel webhook URL for outbound events
# Get from: GHL Dashboard -> Automation -> Webhooks
GHL_WEBHOOK_URL=https://your-ghl-webhook-url

# Optional: Secret for verifying inbound GHL webhook requests
# Generate: openssl rand -hex 32
GHL_INBOUND_WEBHOOK_SECRET=your-ghl-webhook-secret

# -----------------------------------------------------------------------------
# 8. Azure Speech (Pronunciation Scoring)
# -----------------------------------------------------------------------------

# Optional: Azure Cognitive Services Speech key for pronunciation assessment
# Get from: Azure Portal -> Speech Services -> Keys and Endpoint
AZURE_SPEECH_KEY=your-azure-speech-key

# Optional: Azure Speech region (e.g., eastus, westus2, southeastasia)
# Get from: Azure Portal -> Speech Services -> Keys and Endpoint
AZURE_SPEECH_REGION=eastus

# -----------------------------------------------------------------------------
# 9. App Configuration
# -----------------------------------------------------------------------------

# Public-facing app URL (used for Mux upload callbacks, certificate verification links)
# Set to your deployed domain in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for authenticating cron job requests (e.g., GHL sync, inactive user checks)
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Secret for verifying external enrollment webhook requests (e.g., from payment provider)
# Generate: openssl rand -hex 32
ENROLLMENT_WEBHOOK_SECRET=your-shared-secret-here
